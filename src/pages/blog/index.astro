---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/widgets/Header.astro';
import Footer from '../../components/widgets/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout
  title="Blog | Axiora"
  description="Practical guides and insights on data analysis for small business owners and teams. No technical background required."
>
  <Header />

  <main>
    <section class="py-20 bg-gradient-to-br from-blue-50 via-indigo-50 to-purple-50 dark:from-gray-900 dark:via-blue-900/20 dark:to-purple-900/20">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-6">Blog</h1>
        <p class="text-xl text-gray-600 dark:text-gray-300">
          Practical guides and insights on data analysis — no technical background required.
        </p>
      </div>
    </section>

    <section class="py-20 bg-white dark:bg-gray-900">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 gap-8">
          {posts.map((post) => (
            <article class="bg-gray-50 dark:bg-gray-800 rounded-lg p-6 flex flex-col hover:shadow-lg transition-shadow duration-300">
              <span class="inline-block px-3 py-1 text-xs font-semibold text-blue-700 dark:text-blue-300 bg-blue-100 dark:bg-blue-900/40 rounded-full mb-4 w-fit">
                {post.data.category}
              </span>
              <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-3 leading-snug">
                {post.data.title}
              </h2>
              <p class="text-gray-600 dark:text-gray-300 mb-4 flex-1">
                {post.data.description}
              </p>
              <div class="flex items-center justify-between mt-auto pt-4 border-t border-gray-200 dark:border-gray-700">
                <time class="text-sm text-gray-500 dark:text-gray-400">
                  {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <a
                  href={`/blog/${post.slug}`}
                  class="text-sm font-medium text-blue-600 dark:text-blue-400 hover:underline"
                >
                  Read More →
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
